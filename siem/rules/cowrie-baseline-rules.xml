<!--
  Cowrie Honeypot — Baseline Detection Rules
  honeypot-soc-lab | Author: Seif Allah Nazmy

  Phase 1 rules: universal SSH attack patterns observed on any honeypot.
  These rules fire regardless of attacker origin or credentials used.

  Rule ID range: 200001-200004
  Selected to avoid conflict with Wazuh default rules (which use 100001).

  MITRE ATT&CK references included per rule.
-->

<group name="cowrie,honeypot,ssh">

  <!-- RULE 200001: SSH Brute Force Attempt
       MITRE: T1110.001 - Brute Force: Password Guessing
       Tactic: Credential Access | Severity: Medium (level 6) -->
  <rule id="200001" level="6">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.login.failed</field>
    <description>Honeypot: SSH brute force login attempt</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failed,brute_force</group>
  </rule>

  <!-- RULE 200002: Successful Honeypot Login
       MITRE: T1110.001 - Brute Force: Password Guessing (success)
       Tactic: Credential Access | Severity: High (level 10) -->
  <rule id="200002" level="10">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.login.success</field>
    <description>Honeypot: Successful SSH login — attacker now in interactive session</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_success,honeypot_compromise</group>
  </rule>

  <!-- RULE 200003: Post-Login Command Execution
       MITRE: T1059 - Command and Scripting Interpreter
       Tactic: Execution | Severity: High (level 10)
       Requires interact_enabled = true in cowrie.cfg -->
  <rule id="200003" level="10">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.command.input</field>
    <description>Honeypot: Attacker executed post-login command</description>
    <mitre>
      <id>T1059</id>
    </mitre>
    <group>command_execution,post_compromise</group>
  </rule>

  <!-- RULE 200004: Malware Download Attempt
       MITRE: T1105 - Ingress Tool Transfer
       Tactic: Command and Control | Severity: Critical (level 13) -->
  <rule id="200004" level="13">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.session.file_download</field>
    <description>Honeypot: CRITICAL — Attacker attempted file download — possible malware staging</description>
    <mitre>
      <id>T1105</id>
    </mitre>
    <group>malware,file_download,critical</group>
  </rule>

</group>
